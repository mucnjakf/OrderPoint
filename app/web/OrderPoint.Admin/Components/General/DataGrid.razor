@typeparam TItem

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.End" Class="mb-3">
    <MudStack Row="true">
        <MudTextField @bind-Value="SearchQuery"
                      @bind-Value:after="OnSearchChangedAsync"
                      T="string"
                      Label="@SearchLabel"
                      Variant="Variant.Outlined"
                      Clearable="true"
                      DebounceInterval="500"
                      Immediate="false"/>

        @if (CustomFilters is not null)
        {
            @CustomFilters
        }

        <MudSelect @bind-Value="SelectedSortBy"
                   @bind-Value:after="OnSortChangedAsync"
                   T="string"
                   Variant="Variant.Outlined"
                   Label="Sort by"
                   FitContent="true">

            @foreach (string sortBy in SortOptions)
            {
                <MudSelectItem Value="@(sortBy)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body1">@GetSortByLabel(sortBy)</MudText>
                        <MudIcon Icon="@GetSortByIcon(sortBy)" Size="Size.Small"/>
                    </MudStack>
                </MudSelectItem>
            }
        </MudSelect>
    </MudStack>

    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Color="Color.Primary"
               Href="@CreateButtonRoute">
        @CreateButtonText
    </MudButton>
</MudStack>

<MudTable Items="Items" Hover="true" Loading="@IsLoading" LoadingProgressColor="Color.Primary">
    <HeaderContent>
        @TableHeaders
    </HeaderContent>

    <RowTemplate>
        @RowTemplate(context)
    </RowTemplate>

    <NoRecordsContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-10">
            <MudIcon Icon="@EmptyStateIcon" Size="Size.Large" Color="Color.Default"/>
            <MudText Typo="Typo.h6">@EmptyStateTitle</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default">
                @if (!string.IsNullOrWhiteSpace(SearchQuery) || HasActiveFilters)
                {
                    <MudText Typo="Typo.caption">"Try adjusting your filters or search query."</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">@EmptyStateMessage</MudText>
                }
            </MudText>
        </MudStack>
    </NoRecordsContent>
</MudTable>

@if (Pagination is not null && Pagination.TotalPages > 1)
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
        <MudText Typo="Typo.caption" Color="Color.Default">
            Showing @((Pagination.PageNumber - 1) * Pagination.PageSize + 1)
            to @(Math.Min(Pagination.PageNumber * Pagination.PageSize, Pagination.TotalCount))
            of @Pagination.TotalCount items
        </MudText>

        <MudPagination Count="Pagination.TotalPages"
                       Selected="Pagination.PageNumber"
                       SelectedChanged="OnPageChanged"
                       BoundaryCount="1"
                       MiddleCount="3"
                       ShowFirstButton="true"
                       ShowLastButton="true"/>
    </MudStack>
}

@code {

    [Parameter]
    [EditorRequired]
    public IReadOnlyList<TItem> Items { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public PaginationDto<TItem>? Pagination { get; set; }

    [Parameter]
    [EditorRequired]
    public bool IsLoading { get; set; }

    [Parameter]
    [EditorRequired]
    public RenderFragment TableHeaders { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public RenderFragment<TItem> RowTemplate { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public EventCallback<DataGridFilters> OnFiltersChanged { get; set; }

    [Parameter]
    public RenderFragment? CustomFilters { get; set; }

    [Parameter]
    [EditorRequired]
    public string SearchLabel { get; set; }

    [Parameter]
    [EditorRequired]
    public IReadOnlyList<string> SortOptions { get; set; } = [];

    [Parameter]
    [EditorRequired]
    public Func<string, string> GetSortByLabel { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public Func<string, string> GetSortByIcon { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string DefaultSortBy { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string CreateButtonRoute { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string CreateButtonText { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string EmptyStateIcon { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string EmptyStateTitle { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public string EmptyStateMessage { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public bool HasActiveFilters { get; set; }

    string? SearchQuery { get; set; }
    string? SelectedSortBy { get; set; }

    protected override void OnInitialized()
    {
        SelectedSortBy = DefaultSortBy;
    }

    async Task OnSearchChangedAsync()
    {
        await NotifyFiltersChanged();
    }

    async Task OnSortChangedAsync()
    {
        await NotifyFiltersChanged();
    }

    public async Task OnPageChanged(int pageNumber)
    {
        await OnFiltersChanged.InvokeAsync(new DataGridFilters(
            pageNumber,
            10,
            SearchQuery,
            SelectedSortBy
        ));
    }

    async Task NotifyFiltersChanged()
    {
        await OnFiltersChanged.InvokeAsync(new DataGridFilters(
            1,
            10,
            SearchQuery,
            SelectedSortBy
        ));
    }

    public sealed record DataGridFilters(
        int PageNumber,
        int PageSize,
        string? SearchQuery,
        string? SortBy
    );

}