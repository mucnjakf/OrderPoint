@page "/categories"

<PageTitle>Categories</PageTitle>

<PageHeader Text="Categories" Breadcrumbs="Breadcrumbs"/>

<StatefulView IsLoading="@IsLoadingTop"
              ShowContent="@TopCategories.Any()"
              EmptyStateIcon="@Icons.Material.Filled.Category"
              EmptyStateText="@("No categories found")">
    <TopCategoryStack Categories="@TopCategories"/>
</StatefulView>

<DataTable TItem="@CategoryDto"
           Items="@Categories"
           Pagination="@Pagination"
           IsLoading="@IsLoading"
           CreateButtonText="@("New category")"
           CreateButtonHref="@("/categories/create")"
           DetailsButtonHref="@(category => $"/categories/{category.Id}")"
           UpdateButtonHref="@(category => $"/categories/{category.Id}/update?returnUrl=/categories")"
           DeleteButtonDisabled="@(category => category.ItemsCount > 0)"
           DeleteButtonDisabledTooltipText="@("Category contains items")"
           OnDeleteClick="@(category => ShowDeleteCategoryDialogAsync(category.Id, category.Name))"
           SearchLabel="@("Search by name")"
           SearchQuery="@SearchQuery"
           SearchQueryChanged="@(value => SearchQuery = value)"
           SelectedSortBy="@SelectedSortBy"
           SelectedSortByChanged="@(value => SelectedSortBy = value)"
           SortByOptions="@Enum.GetNames(typeof(CategorySortBy))"
           GetSortByLabel="@CategorySorting.GetSortByLabel"
           GetSortByIcon="@CategorySorting.GetSortByIcon"
           OnSearchChanged="@OnSearchChangedAsync"
           OnSortChanged="@OnSortChangedAsync"
           OnPageChanged="@OnPageChanged"
           EmptyStateIcon="@Icons.Material.Filled.Category"
           EmptyStateText="@("No categories found")">
    <FilterContent>
        <MudSelect @bind-Value="SelectedStatus"
                   @bind-Value:after="OnStatusChangedAsync"
                   T="CategoryStatus?"
                   Variant="Variant.Outlined"
                   Label="@("Status")"
                   FitContent="true">

            <MudSelectItem Value="@(null)" T="CategoryStatus?">
                <MudText>All</MudText>
            </MudSelectItem>

            @foreach (CategoryStatus status in Enum.GetValues<CategoryStatus>())
            {
                <MudSelectItem Value="@(status)" T="CategoryStatus?">
                    <MudText>
                        @status.ToString()
                    </MudText>
                </MudSelectItem>
            }
        </MudSelect>

    </FilterContent>

    <HeaderContent>
        <MudTh Style="width: 100px;"></MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Items</MudTh>
        <MudTh>Created</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd Class="d-flex justify-end">
            <MudImage Src="@(context.ImageUrl ?? "images/image-placeholder.svg")"
                      Alt="Category image"
                      Width="55"
                      Height="55"/>
        </MudTd>

        <MudTd DataLabel="Name">
            @context.Name
        </MudTd>

        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Variant="Variant.Text"
                     Color="@(context.Status is CategoryStatus.Active ? Color.Success : Color.Error)">
                @context.Status.ToString()
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Items">
            @context.ItemsCount items
        </MudTd>

        <MudTd DataLabel="Created">
            @context.CreatedAtUtc.ToString("G")
        </MudTd>
    </RowTemplate>
</DataTable>