@page "/categories/{id:guid}"

<PageTitle>Category details</PageTitle>

<PageHeader Text="Category details" Breadcrumbs="Breadcrumbs"/>

<StatefulView IsLoading="IsLoading" ShowContent="true">
    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" md="4">
            <CategoryPreviewPaper Category="Category"/>
        </MudItem>

        <MudItem xs="12" md="8">
            <CategoryDetailsPaper Category="Category"
                                  OnDeleteClick="ShowDeleteCategoryDialogAsync"/>
        </MudItem>
    </MudGrid>
</StatefulView>

<CategoryItemsSection Items="Items"
                      Pagination="Pagination"
                      IsLoading="IsLoadingItems"
                      SearchQuery="@SearchQuery"
                      SearchQueryChanged="value => SearchQuery = value"
                      SelectedSortBy="@SelectedSortBy"
                      SelectedSortByChanged="value => SelectedSortBy = value"
                      OnSearchChanged="OnSearchChangedAsync"
                      OnSortChanged="OnSortChangedAsync"
                      OnPageChanged="OnPageChanged"/>