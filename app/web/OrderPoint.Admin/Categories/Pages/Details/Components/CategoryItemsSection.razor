<MudText Typo="Typo.h5">Items</MudText>

@* TODO: maybe add create update *@
<DataTable TItem="ItemDto"
           Items="Items"
           Pagination="Pagination"
           IsLoading="IsLoading"
           DetailsButtonHref="@(item => $"/items/{item.Id}")"
           DeleteButtonDisabled="@(item => false)"
           DeleteButtonDisabledTooltipText="@string.Empty"
           OnDeleteClick="@(item => ShowDeleteItemDialogAsync(item.Id, item.Name))"
           SearchLabel="Search by name"
           SearchQuery="@SearchQuery"
           SearchQueryChanged="SearchQueryChanged"
           SelectedSortBy="@SelectedSortBy"
           SelectedSortByChanged="SelectedSortByChanged"
           SortByOptions="Enum.GetNames(typeof(ItemSortBy))"
           GetSortByLabel="ItemSorting.GetSortByLabel"
           GetSortByIcon="ItemSorting.GetSortByIcon"
           OnSearchChanged="OnSearchChanged"
           OnSortChanged="OnSortChanged"
           OnPageChanged="OnPageChanged"
           EmptyStateIcon="@Icons.Material.Filled.MenuBook"
           EmptyStateText="No items found">
    <HeaderContent>
        <MudTh Style="width: 100px"></MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Portion</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>Created</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd Class="d-flex justify-end">
            <MudImage Src="@(context.ImageUrl ?? "images/image-placeholder.svg")"
                      Alt="Category image"
                      Width="55"
                      Height="55"/>
        </MudTd>

        <MudTd DataLabel="Name">
            @context.Name
        </MudTd>

        <MudTd DataLabel="Portion">
            @context.Portion
        </MudTd>

        <MudTd DataLabel="Price">
            @context.Price.ToString("C", CultureInfo.CurrentCulture)
        </MudTd>

        <MudTd DataLabel="Created">
            @context.CreatedAtUtc.ToString("G")
        </MudTd>
    </RowTemplate>
</DataTable>