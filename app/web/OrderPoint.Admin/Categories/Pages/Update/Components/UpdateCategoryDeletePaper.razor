<MudPaper Class="pa-5">
    <MudText Typo="Typo.body2" Class="mb-3">
        @(CategoryContainsItems ? "Category contains items." : "Permanently delete this category. This action cannot be undone.")
    </MudText>

    <MudButton Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Delete"
               FullWidth="true"
               Color="Color.Error"
               Disabled="CategoryContainsItems"
               OnClick="OnDeleteClick">
        Delete
    </MudButton>
</MudPaper>