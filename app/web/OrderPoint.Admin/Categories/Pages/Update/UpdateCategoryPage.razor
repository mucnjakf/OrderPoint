@page "/categories/{id:guid}/update"

<PageTitle>Edit category</PageTitle>

<PageHeader Text="Edit category" Breadcrumbs="Breadcrumbs"/>

<StatefulView IsLoading="@IsLoading"
              ShowContent="@(Request is not null)"
              EmptyStateIcon="@Icons.Material.Filled.Category"
              EmptyStateText="@("No category found")">
    <MudGrid Spacing="3" Class="mb-3">
        <MudItem xs="12" md="8">
            <EditForm Model="@Request" OnValidSubmit="OnValidSubmitAsync">
                <DataAnnotationsValidator/>

                <MudCard Class="pa-3" Style="height: 100%;">
                    <MudCardContent>
                        <MudTextField Label="Name"
                                      @bind-Value="Request.Name"
                                      For="@(() => Request.Name)"
                                      Class="mb-5 mt-0"
                                      HelperText="The display name of the category shown to customers."
                                      Variant="Variant.Outlined"
                                      Immediate="true"/>

                        <MudTextField Label="Description"
                                      @bind-Value="Request.Description"
                                      For="@(() => Request.Description)"
                                      HelperText="A brief description of what this category contains."
                                      Variant="Variant.Outlined"
                                      Class="mb-5"
                                      Lines="5"
                                      Immediate="true"/>

                        <MudStack Row="true">
                            <MudSelect Label="Status"
                                       T="CategoryStatus"
                                       @bind-Value="Request.Status"
                                       For="@(() => Request.Status)"
                                       HelperText="Controls whether this category is visible to customers."
                                       Variant="Variant.Outlined">
                                @foreach (CategoryStatus status in Enum.GetValues<CategoryStatus>())
                                {
                                    <MudSelectItem Value="@status" T="CategoryStatus">
                                        <MudText>
                                            @status.ToString()
                                        </MudText>
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField Label="Image URL"
                                          Disabled="true"
                                          @bind-Value="Request.ImageUrl"
                                          For="@(() => Request.ImageUrl)"
                                          HelperText="Image upload will be available in a future update."
                                          Variant="Variant.Outlined"/>
                        </MudStack>
                    </MudCardContent>

                    <MudCardActions Class="pa-4 d-flex justify-end">
                        <MudButton Href="@(ReturnUrl ?? "/categories")" Variant="Variant.Text" Class="mr-5">
                            Cancel
                        </MudButton>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Edit">
                            Confirm
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudStack Spacing="3" Style="height: 100%;">
                <CategoryPreviewPaper Name="@Request.Name"
                                      Description="@Request.Description"
                                      Status="@Request.Status"
                                      NamePlaceholder="Category name"
                                      DescriptionPlaceholder="Category description"/>

                <UpdateCategoryDeletePaper CategoryContainsItems="@CategoryContainsItems"
                                           OnDeleteClick="ShowDeleteCategoryDialogAsync"/>
            </MudStack>
        </MudItem>
    </MudGrid>
</StatefulView>