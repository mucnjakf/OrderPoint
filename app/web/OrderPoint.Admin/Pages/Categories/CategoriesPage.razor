@page "/categories"

<PageTitle>Categories</PageTitle>

<Breadcrumbs Items="Breadcrumbs"/>

<MainTitle Text="Categories"/>

<TopCategoriesSection Categories="TopCategories" IsLoading="IsLoadingTop"/>

<DataGrid TItem="CategoryDto"
          Items="Categories"
          Pagination="Pagination"
          IsLoading="IsLoading"
          SearchLabel="Search by name"
          SortOptions="@Enum.GetNames(typeof(CategorySortBy))"
          GetSortByLabel="CategorySortingHelpers.GetSortByLabel"
          GetSortByIcon="CategorySortingHelpers.GetSortByIcon"
          DefaultSortBy="CreatedAtUtcDesc"
          CreateButtonRoute="/categories/create"
          CreateButtonText="New category"
          EmptyStateIcon="@Icons.Material.Filled.Category"
          EmptyStateTitle="No categories found"
          EmptyStateMessage="Get started by creating your first category."
          HasActiveFilters="@(!string.IsNullOrWhiteSpace(SelectedStatus?.ToString()))"
          OnFiltersChanged="HandleFiltersChangedAsync">

    <CustomFilters>
        <MudSelect @bind-Value="SelectedStatus"
                   @bind-Value:after="OnStatusChangedAsync"
                   T="CategoryStatus?"
                   Variant="Variant.Outlined"
                   Label="Status"
                   FitContent="true">

            <MudSelectItem Value="@(null)" T="CategoryStatus?">
                <MudText>All</MudText>
            </MudSelectItem>

            @foreach (CategoryStatus status in Enum.GetValues<CategoryStatus>())
            {
                <MudSelectItem Value="@(status)" T="CategoryStatus?">
                    <MudText Color="@(status is CategoryStatus.Active ? Color.Success : Color.Error)">
                        @status.ToString()
                    </MudText>
                </MudSelectItem>
            }
        </MudSelect>
    </CustomFilters>

    <TableHeaders>
        <MudTh Style="width: 105px;"></MudTh>
        <MudTh Style="width: 325px;">Name</MudTh>
        <MudTh Style="width: 185px;">Status</MudTh>
        <MudTh Style="width: 170px;">Items</MudTh>
        <MudTh Style="width: 260px;">Created</MudTh>
        <MudTh Style="width: 150px;"></MudTh>
    </TableHeaders>

    <RowTemplate Context="category">
        <MudTd DataLabel="">
            <MudIcon Icon="@Icons.Material.Filled.CropOriginal" Size="Size.Large" Title="Placeholder"/>
        </MudTd>

        <MudTd DataLabel="Name">@category.Name</MudTd>

        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Variant="Variant.Text"
                     Color="@(category.Status is CategoryStatus.Active ? Color.Success : Color.Error)">
                @category.Status.ToString()
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Items">@category.ItemsCount items</MudTd>

        <MudTd DataLabel="Created at">@category.CreatedAtUtc.ToString("G")</MudTd>

        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.RemoveRedEye"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Href="@($"/categories/{category.Id}")"/>

            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Secondary"
                           Size="Size.Small"
                           Class="mx-2"
                           Href="@($"/categories/{category.Id}/update?returnUrl=/categories")"/>

            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Size="Size.Small"
                           Disabled="category.ItemsCount > 0"
                           OnClick="() => ShowDeleteCategoryDialogAsync(category.Id, category.Name)"/>
        </MudTd>
    </RowTemplate>
</DataGrid>

@code {

    [Inject]
    IDialogService DialogService { get; set; } = null!;

    [Inject]
    ISnackbar Snackbar { get; set; } = null!;

    [Inject]
    CategoryApiClient CategoryApiClient { get; set; } = null!;

    List<BreadcrumbItem> Breadcrumbs { get; set; } =
    [
        new("Dashboard", href: "/", icon: Icons.Material.Filled.Dashboard),
        new("Categories", href: null, disabled: true, icon: Icons.Material.Filled.Category)
    ];

    IReadOnlyList<CategoryDto> TopCategories { get; set; } = [];

    PaginationDto<CategoryDto>? Pagination { get; set; }
    IReadOnlyList<CategoryDto> Categories { get; set; } = [];

    string SelectedSortBy { get; set; } = "CreatedAtUtcDesc";
    string? SearchQuery { get; set; }
    CategoryStatus? SelectedStatus { get; set; }

    bool IsLoadingTop { get; set; } = true;
    bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await GetTopCategoriesAsync();

        await GetCategoriesAsync(
            1,
            10,
            SelectedSortBy,
            SearchQuery,
            SelectedStatus);
    }

    async Task GetTopCategoriesAsync()
    {
        try
        {
            IsLoadingTop = true;

            PaginationDto<CategoryDto> pagination = await CategoryApiClient
                .GetCategoriesAsync(1, 5, "ItemsCountDesc");

            TopCategories = pagination.Items;
        }
        finally
        {
            IsLoadingTop = false;
        }
    }

    async Task GetCategoriesAsync(
        int pageNumber,
        int pageSize,
        string sortBy,
        string? searchQuery,
        CategoryStatus? status)
    {
        try
        {
            IsLoading = true;

            Pagination = await CategoryApiClient.GetCategoriesAsync(
                pageNumber,
                pageSize,
                sortBy,
                searchQuery,
                status);

            Categories = Pagination.Items;
        }
        finally
        {
            IsLoading = false;
        }
    }

    async Task HandleFiltersChangedAsync(DataGrid<CategoryDto>.DataGridFilters filters)
    {
        SearchQuery = filters.SearchQuery;
        SelectedSortBy = filters.SortBy ?? SelectedSortBy;

        await GetCategoriesAsync(
            filters.PageNumber,
            filters.PageSize,
            SelectedSortBy,
            SearchQuery,
            SelectedStatus);
    }

    async Task OnStatusChangedAsync()
    {
        await HandleFiltersChangedAsync(new DataGrid<CategoryDto>.DataGridFilters(
            1,
            10,
            SearchQuery,
            SelectedSortBy));
    }

    async Task ShowDeleteCategoryDialogAsync(Guid categoryId, string categoryName)
    {
        var parameters = new DialogParameters<DeleteCategoryDialog>
        {
            { dialog => dialog.CategoryName, categoryName }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        IDialogReference dialogReference = await DialogService
            .ShowAsync<DeleteCategoryDialog>(string.Empty, parameters, options);

        DialogResult dialogResult = (await dialogReference.Result)!;

        if (!dialogResult.Canceled)
        {
            await CategoryApiClient.DeleteCategoryAsync(categoryId);

            Snackbar.Add($"Category {categoryName} deleted successfully", Severity.Success);

            await GetTopCategoriesAsync();

            await GetCategoriesAsync(
                1,
                10,
                SelectedSortBy,
                SearchQuery,
                SelectedStatus);
        }
    }

}