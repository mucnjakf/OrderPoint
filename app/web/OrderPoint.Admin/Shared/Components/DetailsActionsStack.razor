<MudStack Row="true" Justify="Justify.SpaceBetween">
    <MudText></MudText>

    <MudStack Row="true" AlignItems="AlignItems.End">
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Edit"
                   Color="Color.Primary"
                   Href="@UpdateButtonHref">
            Edit
        </MudButton>

        @if (DeleteButtonDisabled && DeleteButtonDisabledTooltipText is not null)
        {
            <MudTooltip Text="@DeleteButtonDisabledTooltipText">
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Disabled="true">
                    Delete
                </MudButton>
            </MudTooltip>
        }
        else
        {
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       OnClick="OnDeleteClickAsync">
                Delete
            </MudButton>
        }
    </MudStack>
</MudStack>