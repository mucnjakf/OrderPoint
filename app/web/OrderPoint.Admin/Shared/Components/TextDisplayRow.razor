<MudStack Row="true" Class="d-flex align-center">
    <MudIcon Icon="@Icon" Size="Size.Small" Color="Color.Surface"/>

    <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">
        @Label
    </MudText>

    <MudText Typo="Typo.body1">
        @Text
    </MudText>
</MudStack>

@if (ShowDivider)
{
    <MudDivider Class="my-1"/>
}