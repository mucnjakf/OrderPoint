@if (IsLoading)
{
    <MudPaper Class="pa-10 d-flex justify-center mb-3">
        <MudProgressCircular Indeterminate="true" Style="height:100px;width:100px;">
            <ChildContent>
                Loading...
            </ChildContent>
        </MudProgressCircular>
    </MudPaper>
}
else if (ShowContent)
{
    @ChildContent
}
else
{
    <MudPaper Class="pa-10 mb-3">
        <MudStack AlignItems="AlignItems.Center">
            <MudIcon Icon="@EmptyStateIcon" Size="Size.Large" Class="mb-1"/>

            <MudText Typo="Typo.body1">
                @EmptyStateText
            </MudText>
        </MudStack>
    </MudPaper>
}