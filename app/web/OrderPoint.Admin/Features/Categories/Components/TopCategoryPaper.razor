<MudPaper Class="pa-10 d-flex flex-column align-center justify-center flex-1"
          Style="cursor: pointer; transition: all 0.2s ease-in-out; height: 180px;"
          Elevation="@(HoveredCategoryId == Category.Id ? 10 : 1)"
          @onclick="@(() => NavigationManager.NavigateTo($"/categories/{Category.Id}"))"
          @onmouseover="() => HoveredCategoryId = Category.Id"
          @onmouseout="() => HoveredCategoryId = null">

    <MudIcon Icon="@Icons.Material.Filled.CropOriginal"
             Title="@Category.Name"
             Size="Size.Large"
             Class="mb-3"/>

    <MudText Typo="Typo.body1" Class="mb-1" Align="Align.Center">
        @Category.Name
    </MudText>

    <MudText Typo="Typo.caption">
        @Category.ItemsCount @(Category.ItemsCount == 1 ? "item" : "items")
    </MudText>
</MudPaper>