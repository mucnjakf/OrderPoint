@page "/categories/{id:guid}"

<PageTitle>Category details</PageTitle>

<MudBreadcrumbs Items="Breadcrumbs" Class="px-0 pt-0 pb-5" Style="font-size: 14px"/>

@if (IsLoading)
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudSkeleton SkeletonType="SkeletonType.Text" Width="200px" Height="40px"/>

        <MudStack Row="true" Spacing="2">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100px" Height="36px"/>
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100px" Height="36px"/>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="d-flex flex-column flex-grow-1 align-center justify-center pa-8" Style="height: 360px;">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="48px" Height="48px" Class="mb-4"/>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="150px" Class="mb-2"/>
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="80px" Height="32px"/>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="pa-5" Style="height: 360px;">
                <MudStack>
                    @for (var i = 0; i < 6; i++)
                    {
                        <MudStack Row="true" Class="d-flex align-center">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="24px" Height="24px"/>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Class="mx-3"/>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%"/>
                        </MudStack>

                        if (i < 5)
                        {
                            <MudDivider Class="my-1"/>
                        }
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4" Class="mb-3">@($"{Category.Name} details")</MudText>

        <MudStack Row="true" AlignItems="AlignItems.End" Class="mb-3">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                       Href="@($"/categories/{Category.Id}/update?returnUrl=/categories/{Category.Id}")">
                Edit
            </MudButton>

            @if (Category.ItemsCount > 0)
            {
                <MudTooltip Text="Category contains items">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Disabled="true">
                        Delete
                    </MudButton>
                </MudTooltip>
            }
            else
            {
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           OnClick="ShowDeleteCategoryDialogAsync">
                    Delete
                </MudButton>
            }
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" md="4">
            <MudPaper Class="d-flex flex-column flex-grow-1 align-center justify-center" Style="height: 100%">
                <MudIcon Icon="@Icons.Material.Filled.CropOriginal" Title="Category name" Size="Size.Large"
                         Class="mb-4"/>

                <MudText Typo="Typo.body1" Class="mb-2">
                    @Category.Name
                </MudText>

                <MudChip T="string" Variant="Variant.Text"
                         Color="@(Category.Status is CategoryStatus.Active ? Color.Success : Color.Error)">
                    @Category.Status.ToString()
                </MudChip>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="pa-5">
                <MudStack>
                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Numbers" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">ID</MudText>

                        <MudText Typo="Typo.body1">@Category.Id</MudText>
                    </MudStack>

                    <MudDivider Class="my-1"/>

                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.ShortText" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">Name</MudText>

                        <MudText Typo="Typo.body1">@Category.Name</MudText>
                    </MudStack>

                    <MudDivider Class="my-1"/>

                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">Description</MudText>

                        <MudText Typo="Typo.body1">@Category.Description</MudText>
                    </MudStack>

                    <MudDivider Class="my-1"/>

                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">Status</MudText>

                        <MudChip T="string" Variant="Variant.Text" Class="ma-0"
                                 Color="@(Category.Status is CategoryStatus.Active ? Color.Success : Color.Error)">
                            @Category.Status.ToString()
                        </MudChip>
                    </MudStack>

                    <MudDivider Class="my-1"/>

                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">Created</MudText>

                        <MudText Typo="Typo.body1">@Category.CreatedAtUtc.ToString("G")</MudText>
                    </MudStack>

                    <MudDivider Class="my-1"/>

                    <MudStack Row="true" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Color="Color.Surface"/>

                        <MudText Class="mr-5" Color="Color.Surface" Typo="Typo.body2">Updated</MudText>

                        <MudText Typo="Typo.body1">
                            @(Category.UpdatedAtUtc is null ? "-" : Category.UpdatedAtUtc.Value.ToString("G"))
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<MudText Typo="Typo.h5">Items</MudText>

<MudDivider Class="my-2"/>

@if (Items.Any())
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.End" Class="mb-3">
        <MudStack Row="true">
            <MudTextField @bind-Value="SearchQuery"
                          @bind-Value:after="OnSearchChangedAsync"
                          T="string"
                          Label="Search by name"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          DebounceInterval="500"
                          Immediate="false"/>

            <MudSelect @bind-Value="SelectedSortBy"
                       @bind-Value:after="OnSortChangedAsync"
                       T="string"
                       Variant="Variant.Outlined"
                       Label="Sort by"
                       FitContent="true">

                @foreach (string sortBy in Enum.GetNames(typeof(ItemSortBy)))
                {
                    <MudSelectItem Value="@(sortBy)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body1">@ItemSorting.GetSortByLabel(sortBy)</MudText>
                            <MudIcon Icon="@ItemSorting.GetSortByIcon(sortBy)" Size="Size.Small"/>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </MudStack>
}

<MudTable Items="Items" Hover="true" Loading="@IsLoadingItems" LoadingProgressColor="Color.Primary">
    <HeaderContent>
        <MudTh Style="width: 105px;"></MudTh>
        <MudTh Style="width: 325px;">Name</MudTh>
        <MudTh Style="width: 150px;">Portion</MudTh>
        <MudTh Style="width: 150px;">Price</MudTh>
        <MudTh Style="width: 260px;">Created</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="">
            <MudIcon Icon="@Icons.Material.Filled.CropOriginal" Size="Size.Large" Title="Placeholder"/>
        </MudTd>

        <MudTd DataLabel="Name">@context.Name</MudTd>

        <MudTd DataLabel="Portion">@context.Portion</MudTd>

        <MudTd DataLabel="Price">$ @context.Price</MudTd>

        <MudTd DataLabel="Created">@context.CreatedAtUtc.ToString("G")</MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-10">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Default"/>
            <MudText Typo="Typo.h6">No items found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default">
                @if (!string.IsNullOrWhiteSpace(SearchQuery))
                {
                    <MudText Typo="Typo.caption">Try adjusting your search query.</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">Get started by creating your first item.</MudText>
                }
            </MudText>
        </MudStack>
    </NoRecordsContent>
</MudTable>

@if (Pagination is not null && Pagination.TotalPages > 1)
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
        <MudText Typo="Typo.caption" Color="Color.Default">
            Showing @((Pagination.PageNumber - 1) * Pagination.PageSize + 1)
            to @(Math.Min(Pagination.PageNumber * Pagination.PageSize, Pagination.TotalCount))
            of @Pagination.TotalCount items
        </MudText>

        <MudPagination Count="Pagination.TotalPages"
                       Selected="Pagination.PageNumber"
                       SelectedChanged="OnPageChanged"
                       BoundaryCount="1"
                       MiddleCount="3"
                       ShowFirstButton="true"
                       ShowLastButton="true"/>
    </MudStack>
}
