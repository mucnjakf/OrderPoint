@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="@IsDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton
            Icon="@Icons.Material.Filled.Menu"
            Color="Color.Inherit"
            Edge="Edge.Start"
            OnClick="@(_ => ToggleDrawer())"/>

        <MudStack Class="ml-3" Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.CropOriginal" Title="Placeholder" Size="Size.Large"/>

            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">OrderPoint</MudText>
                <MudText Typo="Typo.caption">Admin panel</MudText>
            </MudStack>
        </MudStack>

        <MudSpacer/>

        <MudIconButton Icon="@(IconButton)" OnClick="@(_ => ToggleDarkMode())" Color="Color.Inherit"/>
    </MudAppBar>

    <MudDrawer @bind-Open="@DrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="DrawerVariant.Mini">
        <MudNavMenu Bordered="true">
            @if (DrawerOpen)
            {
                <MudText Typo="Typo.button" HtmlTag="h1" Class="px-3 pt-3 pb-1" Style="font-size: 12px">
                    Overview
                </MudText>
            }

            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                <MudText Typo="Typo.body1">Dashboard</MudText>
            </MudNavLink>

            <MudNavLink Href="/orders" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Receipt">
                <MudText Typo="Typo.body1">Orders</MudText>
            </MudNavLink>

            <MudDivider Class="my-3"/>

            @if (DrawerOpen)
            {
                <MudText Typo="Typo.button" HtmlTag="h1" Class="px-3 pt-1 pb-1" Style="font-size: 12px">
                    Management
                </MudText>
            }

            <MudNavLink Href="/bartenders" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
                <MudText Typo="Typo.body1">Bartenders</MudText>
            </MudNavLink>

            <MudNavLink Href="/items" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook">
                <MudText Typo="Typo.body1">Items</MudText>
            </MudNavLink>

            <MudNavLink Href="/categories" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Category">
                <MudText Typo="Typo.body1">Categories</MudText>
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer Class="pa-3">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool DrawerOpen { get; set; } = true;

    bool IsDarkMode { get; set; } = true;

    string IconButton { get; set; } = Icons.Material.Filled.LightMode;

    void ToggleDrawer()
    {
        DrawerOpen = !DrawerOpen;
    }

    void ToggleDarkMode()
    {
        IsDarkMode = !IsDarkMode;

        if (IsDarkMode)
        {
            IconButton = Icons.Material.Filled.LightMode;
            return;
        }

        IconButton = Icons.Material.Filled.DarkMode;
    }

}